{
  "name": "mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "detox:build:android": "detox build -c android.emu.debug",
    "detox:test:android": "detox test -c android.emu.debug --headless",
    "detox:test:android:reuse": "detox test -c android.emu.debug --reuse --headless",
    "e2e:android": "yarn detox:build:android && yarn detox:test:android",
    "e2e:android:reuse": "yarn detox:test:android:reuse",
    "e2e:android:file": "DETOX_CONFIGURATION=android.emu.debug jest --config e2e/jest.config.js",
    "launch:android": "sh -c 'adb -e shell am start -W -a android.intent.action.VIEW -d \"$DEEPLINK\" || adb shell am start -W -a android.intent.action.VIEW -d \"$DEEPLINK\"'",
    "launch:ios": "sh -c 'xcrun simctl openurl booted \"$DEEPLINK\"'"
  },
  "dependencies": {
    "@libp2p/circuit-relay-v2": "^4.1.3",
    "@libp2p/websockets": "^10.1.3",
    "@noble/hashes": "^2.0.0",
    "@optimystic/db-core": "portal:../../../optimystic/packages/db-core",
    "@optimystic/db-p2p": "portal:../../../optimystic/packages/db-p2p",
    "@optimystic/db-p2p-storage-rn": "portal:../../../optimystic/packages/db-p2p-storage-rn",
    "@optimystic/quereus-plugin-crypto": "portal:../../../optimystic/packages/quereus-plugin-crypto",
    "@optimystic/quereus-plugin-optimystic": "portal:../../../optimystic/packages/quereus-plugin-optimystic",
    "@quereus/quereus": "portal:../../../quereus/packages/quereus",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-documents/picker": "^11.0.0",
    "@react-native/new-app-screen": "0.82.1",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/native-stack": "^7.6.2",
    "@serfab/cadre-core": "portal:../../../sereus/packages/cadre-core",
    "@ungap/structured-clone": "^1.3.0",
    "event-target-polyfill": "^0.0.4",
    "p2p-fret": "portal:../../../fret/packages/fret",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-get-random-values": "^1.11.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-permissions": "^5.4.4",
    "react-native-qrcode-svg": "^6.3.20",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.18.0",
    "react-native-svg": "^15.15.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "^4.7.3",
    "rn-leveldb": "^3.11.0",
    "web-streams-polyfill": "^4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/eslint-config": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.1",
    "@types/react-test-renderer": "^19.1.0",
    "detox": "^20.45.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "@optimystic/db-core": "portal:../../../optimystic/packages/db-core",
    "@optimystic/db-p2p": "portal:../../../optimystic/packages/db-p2p",
    "@optimystic/db-p2p-storage-rn": "portal:../../../optimystic/packages/db-p2p-storage-rn",
    "@optimystic/quereus-plugin-crypto": "portal:../../../optimystic/packages/quereus-plugin-crypto",
    "@optimystic/quereus-plugin-optimystic": "portal:../../../optimystic/packages/quereus-plugin-optimystic",
    "@quereus/quereus": "portal:../../../quereus/packages/quereus",
    "@serfab/cadre-core": "portal:../../../sereus/packages/cadre-core",
    "@serfab/strand-proto": "portal:../../../sereus/packages/strand-proto",
    "p2p-fret": "portal:../../../fret/packages/fret",
    "@libp2p/interface": "npm:3.1.0",
    "@libp2p/peer-id": "npm:6.0.4",
    "@multiformats/multiaddr": "npm:13.0.1",
    "libp2p": "npm:3.1.3",
    "@noble/hashes": "npm:2.0.1"
  },
  "detox": {
    "testRunner": {
      "$0": "jest",
      "args": {
        "config": "e2e/jest.config.js",
        "_": [
          "e2e"
        ]
      }
    },
    "apps": {
      "android.debug": {
        "type": "android.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk"
      }
    },
    "devices": {
      "android.emu": {
        "type": "android.emulator",
        "device": {
          "avdName": "Medium_Phone_API_34"
        }
      }
    },
    "configurations": {
      "android.emu.debug": {
        "device": "android.emu",
        "app": "android.debug"
      }
    }
  }
}
